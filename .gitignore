# -----------------------------------------------------------------------------
# Strict allowlist mode: ignore everything by default, then re-include essentials
# -----------------------------------------------------------------------------
*

# Keep git config files
!.gitignore

# Keep core root-level project files
!.env.example
!README.md
!docker-compose.yml

# Keep core application directories
!backend/
!backend/**
!frontend/
!frontend/**
!database/
!database/**
!k8s/
!k8s/**

# -----------------------------------------------------------------------------
# Re-ignore generated/secrets/build/runtime files inside allowed directories
# -----------------------------------------------------------------------------

# Python/backend artifacts
backend/.env
backend/.venv/
backend/venv/
backend/**/__pycache__/
backend/**/*.py[cod]
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/storage/
backend/logs/
backend/config.py

# Frontend artifacts
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.next/
frontend/.cache/
frontend/coverage/

# Infrastructure/runtime noise
certs/
logs/
lightning_logs/

# OS/editor cruft
**/.DS_Store
**/Thumbs.db
**/.idea/
**/.vscode/
