{
  "schema_version": "1.0",
  "schema_name": "Canonical Hospital Resource Forecasting Schema",
  "description": "Standardized schema for multi-hospital resource demand forecasting with temporal features",
  "created_at": "2024-01-01",
  "updated_at": "2024-01-01",
  
  "field_categories": {
    "static_features": {
      "description": "Hospital characteristics that don't change over time",
      "fields": {
        "hospital_id": {
          "type": "string",
          "required": true,
          "description": "Unique hospital identifier",
          "example": "HOSP-001"
        },
        "hospital_name": {
          "type": "string",
          "required": false,
          "description": "Hospital name",
          "example": "City General Hospital"
        },
        "hospital_capacity": {
          "type": "integer",
          "required": true,
          "description": "Total bed capacity",
          "min": 1,
          "example": 500
        },
        "hospital_type": {
          "type": "string",
          "required": false,
          "description": "Type of hospital specialization",
          "enum": ["general", "pediatric", "cardiac", "trauma", "surgical", "teaching"],
          "example": "general"
        },
        "location": {
          "type": "string",
          "required": false,
          "description": "Hospital location (city, region)",
          "example": "New York, NY"
        },
        "num_operating_rooms": {
          "type": "integer",
          "required": false,
          "description": "Number of operating rooms",
          "min": 0,
          "example": 15
        },
        "num_icu_beds": {
          "type": "integer",
          "required": false,
          "description": "Number of ICU beds",
          "min": 0,
          "example": 50
        }
      }
    },
    
    "historical_features": {
      "description": "Time-series observations of hospital resource usage (past data)",
      "fields": {
        "timestamp": {
          "type": "datetime",
          "required": true,
          "description": "Date and time of observation",
          "format": "YYYY-MM-DD HH:MM:SS",
          "example": "2024-01-15 08:00:00"
        },
        "bed_occupancy": {
          "type": "integer",
          "required": true,
          "description": "Number of occupied hospital beds at this time",
          "min": 0,
          "example": 350
        },
        "er_visits": {
          "type": "integer",
          "required": false,
          "description": "Number of emergency room visits",
          "min": 0,
          "example": 45
        },
        "icu_occupancy": {
          "type": "integer",
          "required": false,
          "description": "Number of occupied ICU beds",
          "min": 0,
          "example": 38
        },
        "admissions": {
          "type": "integer",
          "required": false,
          "description": "Number of patient admissions",
          "min": 0,
          "example": 25
        },
        "discharges": {
          "type": "integer",
          "required": false,
          "description": "Number of patient discharges",
          "min": 0,
          "example": 20
        },
        "surgery_count": {
          "type": "integer",
          "required": false,
          "description": "Number of surgeries performed",
          "min": 0,
          "example": 12
        },
        "staff_count": {
          "type": "integer",
          "required": false,
          "description": "Number of staff on duty",
          "min": 0,
          "example": 150
        },
        "average_length_of_stay": {
          "type": "float",
          "required": false,
          "description": "Average patient length of stay in days",
          "min": 0.0,
          "example": 4.5
        }
      }
    },
    
    "known_future_features": {
      "description": "Features known in advance for future time periods",
      "fields": {
        "day_of_week": {
          "type": "integer",
          "required": true,
          "description": "Day of week (0=Monday, 6=Sunday)",
          "min": 0,
          "max": 6,
          "example": 2
        },
        "month": {
          "type": "integer",
          "required": true,
          "description": "Month of year (1=January, 12=December)",
          "min": 1,
          "max": 12,
          "example": 3
        },
        "day_of_month": {
          "type": "integer",
          "required": false,
          "description": "Day of the month",
          "min": 1,
          "max": 31,
          "example": 15
        },
        "hour": {
          "type": "integer",
          "required": false,
          "description": "Hour of day (0-23)",
          "min": 0,
          "max": 23,
          "example": 14
        },
        "is_holiday": {
          "type": "boolean",
          "required": false,
          "description": "Whether this date is a public holiday",
          "example": false
        },
        "is_weekend": {
          "type": "boolean",
          "required": false,
          "description": "Whether this is a weekend (Saturday/Sunday)",
          "example": false
        },
        "season": {
          "type": "string",
          "required": false,
          "description": "Season of the year",
          "enum": ["winter", "spring", "summer", "fall"],
          "example": "spring"
        },
        "is_flu_season": {
          "type": "boolean",
          "required": false,
          "description": "Whether this date falls in flu season (Oct-Mar in Northern Hemisphere)",
          "example": false
        }
      }
    },
    
    "target_variables": {
      "description": "Variables to be predicted (forecast targets)",
      "fields": {
        "future_bed_occupancy": {
          "type": "integer",
          "required": false,
          "description": "Forecasted bed occupancy for future time",
          "min": 0,
          "example": 365
        },
        "future_er_visits": {
          "type": "integer",
          "required": false,
          "description": "Forecasted ER visits",
          "min": 0,
          "example": 50
        },
        "future_icu_occupancy": {
          "type": "integer",
          "required": false,
          "description": "Forecasted ICU occupancy",
          "min": 0,
          "example": 40
        },
        "future_admissions": {
          "type": "integer",
          "required": false,
          "description": "Forecasted patient admissions",
          "min": 0,
          "example": 30
        }
      }
    }
  },
  
  "field_mapping_hints": {
    "timestamp_synonyms": ["date", "datetime", "time", "date_time", "observation_date", "record_date"],
    "bed_occupancy_synonyms": ["beds_occupied", "occupied_beds", "bed_count", "current_beds", "total_beds_used"],
    "er_visits_synonyms": ["emergency_visits", "er_count", "emergency_room_visits", "emergency_cases", "ed_visits"],
    "icu_occupancy_synonyms": ["icu_beds", "icu_count", "intensive_care_beds", "critical_care_beds"],
    "admissions_synonyms": ["patient_admissions", "new_admissions", "admitted_patients", "intake"],
    "discharges_synonyms": ["patient_discharges", "released_patients", "discharged_count"],
    "is_holiday_synonyms": ["holiday", "public_holiday", "holiday_flag", "is_public_holiday"],
    "is_weekend_synonyms": ["weekend", "weekend_flag", "is_saturday_sunday"]
  },
  
  "validation_rules": {
    "bed_occupancy_max": "Must not exceed hospital_capacity",
    "icu_occupancy_max": "Must not exceed num_icu_beds if specified",
    "timestamp_format": "Must be parseable datetime",
    "non_negative": "All count fields must be >= 0"
  },
  
  "extensions": {
    "category_extensions": {
      "description": "Reserved for Phase 11 - Treatment category-specific fields",
      "placeholder": true
    }
  }
}
