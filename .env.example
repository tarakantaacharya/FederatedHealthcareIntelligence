# Security Settings (Phase 20)
FORCE_HTTPS=true
SSL_KEYFILE=/app/certs/key.pem
SSL_CERTFILE=/app/certs/cert.pem

# Blockchain Settings (Phase 18)
BLOCKCHAIN_URL=http://ganache:8545
BLOCKCHAIN_ADMIN_ADDRESS=0xYourAdminAddress
BLOCKCHAIN_ADMIN_PRIVATE_KEY=0xYourPrivateKey
AUDIT_CONTRACT_ADDRESS=0xAuditContractAddress
PARTICIPATION_CONTRACT_ADDRESS=0xParticipationContractAddress

# Key Rotation (Phase 20)
KEY_ROTATION_DAYS=90
